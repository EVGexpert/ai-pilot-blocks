{
  "name": "aipilot/faq",
  "schemaVersion": 4,
  "safeForAgent": true,
  "contentModel": "attributes",
  "purpose": "Секция частых вопросов.",
  "useWhen": [
    "FAQ",
    "возражения",
    "поддержка"
  ],
  "constraints": {
    "recommendedItems": "3-8",
    "headingControls": "headingSize controls the section H2; questionSize controls summary question text."
  },
  "mcp": {
    "registry": true,
    "attributeUpdates": true,
    "treeOperations": true,
    "validation": true
  },
  "placement": {
    "level": "root-section",
    "maxPerPage": 1
  },
  "semantics": {
    "landmark": "section",
    "headingLevel": 2,
    "interaction": "details-summary"
  },
  "accessibility": {
    "nativeDetailsSummary": true,
    "labelledByHeading": true
  },
  "seo": {
    "serverRendered": true,
    "visibleTextOnly": true
  },
  "styleContract": {
    "rootClass": "ap-faq",
    "tokenScope": "shared",
    "classAttributes": {
      "headingSize": {
        "classPrefix": "is-heading-",
        "baseValues": [
          "auto"
        ]
      },
      "questionSize": {
        "classPrefix": "is-question-",
        "baseValues": [
          "auto"
        ]
      }
    }
  }
}
