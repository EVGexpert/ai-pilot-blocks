{
  "name": "aipilot/testimonial",
  "schemaVersion": 2,
  "safeForAgent": true,
  "contentModel": "attributes",
  "purpose": "Выразительная цитата клиента, эксперта или бренда.",
  "useWhen": [
    "отзыв",
    "цитата",
    "принцип компании"
  ],
  "constraints": {
