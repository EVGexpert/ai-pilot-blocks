  },
  "mcp": {
    "registry": true,
    "attributeUpdates": true,
    "treeOperations": true,
    "validation": true
  },
  "placement": {
    "level": "root-section"
  },
  "semantics": {
    "landmark": "section",
    "content": "blockquote"
  },
  "accessibility": {
