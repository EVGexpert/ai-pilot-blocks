{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aipilot/author-box",
  "version": "1.2.4",
  "title": "Автор материала",
  "category": "aipilot",
  "icon": "admin-users",
  "description": "Карточка автора текущей записи или указанного вручную эксперта.",
  "textdomain": "ai-pilot-blocks",
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide",
      "enum": [
        "wide",
        "full"
      ]
    },
    "title": {
      "type": "string",
      "default": "Об авторе"
    },
    "headingSize": {
      "type": "string",
      "default": "sm",
      "enum": [
        "auto",
        "xs",
        "sm",
        "md",
        "lg",
        "xl"
      ]
    },
    "source": {
      "type": "string",
      "default": "post-author",
      "enum": [
        "post-author",
        "manual"
      ]
    },
    "manualName": {
      "type": "string",
      "default": ""
    },
    "manualRole": {
      "type": "string",
      "default": ""
    },
    "manualBio": {
      "type": "string",
      "default": ""
    },
    "manualUrl": {
      "type": "string",
      "default": ""
    },
    "manualImageId": {
      "type": "integer",
      "default": 0
    },
    "showAvatar": {
      "type": "boolean",
      "default": true
    },
    "showBio": {
      "type": "boolean",
      "default": true
    },
    "showPostsLink": {
      "type": "boolean",
      "default": true
    },
    "tone": {
      "type": "string",
      "default": "white",
      "enum": [
        "white",
        "paper",
        "ink"
      ]
    }
  },
  "supports": {
    "anchor": true,
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "editorScript": "file:./index.js",
  "style": "aipilot-blocks-style",
  "editorStyle": "aipilot-blocks-editor-style",
  "render": "file:./render.php",
  "usesContext": [
    "postId",
    "postType"
  ],
  "keywords": [
    "автор",
    "биография",
    "эксперт"
  ],
  "example": {
    "attributes": {
      "tone": "white"
    }
  }
}
