{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aipilot/stats",
  "version": "1.2.4",
  "title": "Показатели",
  "category": "aipilot",
  "icon": "chart-bar",
  "description": "Крупные числа и подписи.",
  "textdomain": "ai-pilot-blocks",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full",
      "enum": [
        "wide",
        "full"
      ]
    },
    "eyebrow": {
      "type": "string",
      "default": "Результаты"
    },
    "title": {
      "type": "string",
      "default": "Цифры говорят сами за себя"
    },
    "tone": {
      "type": "string",
      "default": "ink",
      "enum": [
        "ink",
        "paper"
      ]
    },
    "items": {
      "type": "array",
      "default": [
        {
          "value": "42%",
          "label": "рост показателя"
        },
        {
          "value": "3×",
          "label": "быстрее запуск"
        },
        {
          "value": "24/7",
          "label": "доступность"
        },
        {
          "value": "100%",
          "label": "контроль"
        }
      ],
      "items": {
        "type": "object"
      }
    }
  },
  "supports": {
    "anchor": true,
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "editorScript": "file:./index.js",
  "style": "aipilot-blocks-style",
  "editorStyle": "aipilot-blocks-editor-style",
  "render": "file:./render.php"
}
