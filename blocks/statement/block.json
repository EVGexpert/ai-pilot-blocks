{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aipilot/statement",
  "version": "1.2.4",
  "title": "Большое заявление",
  "category": "aipilot",
  "icon": "editor-quote",
  "description": "Крупная типографическая секция для ключевой мысли.",
  "textdomain": "ai-pilot-blocks",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Ключевая идея"
    },
    "text": {
      "type": "string",
      "default": "Сформулируйте главную мысль одним сильным абзацем."
    },
    "align": {
      "type": "string",
      "default": "left",
      "enum": [
        "left",
        "center"
      ]
    },
    "tone": {
      "type": "string",
      "default": "paper",
      "enum": [
        "paper",
        "white",
        "ink"
      ]
    }
  },
  "supports": {
    "anchor": true,
    "html": false
  },
  "editorScript": "file:./index.js",
  "style": "aipilot-blocks-style",
  "editorStyle": "aipilot-blocks-editor-style",
  "render": "file:./render.php"
}
