{
  "name": "aipilot/section",
  "schemaVersion": 2,
  "safeForAgent": true,
  "contentModel": "attributes",
  "purpose": "Контролируемая секция с фоном, шириной и вертикальным ритмом.",
  "useWhen": [
    "обёртка для стандартных блоков",
    "создание отдельных смысловых секций"
  ],
  "constraints": {
    "recommendedMaxDepth": 2
  },
  "mcp": {
    "registry": true,
    "attributeUpdates": true,
    "treeOperations": true,
    "validation": true
  },
  "placement": {
    "level": "root-or-container"
  },
  "semantics": {
    "landmark": "section"
  },
  "accessibility": {
    "requiresAccessibleNameWhenNoVisibleHeading": true
  },
  "seo": {
    "serverRendered": true,
    "visibleTextOnly": true
  },
  "styleContract": {
    "rootClass": "ap-section",
    "tokenScope": "shared",
    "classAttributes": {
      "tone": {
        "classPrefix": "is-tone-",
        "baseValues": []
      },
      "spacing": {
        "classPrefix": "is-spacing-",
        "baseValues": []
      },
      "width": {
        "classPrefix": "is-width-",
        "baseValues": []
      }
    }
  }
}
